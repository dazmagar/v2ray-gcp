# Required: GCP credentials (path to keys/terraform-new.json)
gcp_credentials_json = "keys/terraform-new.json"
project              = "demo-project-a1b2c3d4"
region               = "europe-west3"
email                = "tf-service@demo-project-a1b2c3d4.iam.gserviceaccount.com"

# Required: SSH keys
user                 = "tfadmin"
publickeypath        = "c:/Users/demo/.ssh/id_rsa.pub"
privatekeypath       = "c:/Users/demo/.ssh/id_rsa"

# Required: V2Ray panel (used in client links)
v2ray_host           = "v2ray.demo-example.com"

# Required: 3x-ui panel
panel_port        = 27419
panel_base_path   = "xui-a8f3b2c4/"   # or "" for default /panel/
panel_host        = ""                # Caddy: empty => panel.<v2ray_host>

# Required: Caddy + proxy
enable_caddy_tls = true
proxy_port       = 8443

# Required: GCP firewall (proxy_port always merged; panel_port merged only if enable_caddy_tls = false)
firewall_tcp_ports = [
  22,
  80,
  443,
  37883,
]
firewall_udp_ports = [
  443,
  31863,
]

# Required: Instance
instance_name        = "v2ray-server-eu-demo"
boot_image           = "ubuntu-2404-lts-amd64"
machine_type         = "e2-micro"
zone_suffix          = "b"

cron_restart_schedule = "15 4 * * *"
backup_path          = "./modules/backup/xui_backup"
